{
  "name": "@talkbox/backend",
  "version": "1.0.0",
  "description": "Talkbox API server — Express 5, Socket.io and Drizzle ORM on Postgres.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test": "vitest"
  },
  "keywords": [
    "express",
    "socket.io",
    "drizzle",
    "postgres",
    "jwt"
  ],
  "author": "Dogukan Kara",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@talkbox/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.7"
  }
}
