# PostgreSQL connection string
# Local example: postgresql://postgres:postgres@localhost:5432/talkbox
# Hosted (Neon): postgresql://user:password@ep-xxx.neon.tech/talkbox?sslmode=require
DATABASE_URL=

# Secret used to sign JWT access tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Allowed origin for CORS and Socket.io. Set to your deployed frontend URL in production.
CLIENT_ORIGIN=http://localhost:5173

# Port the HTTP server listens on
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info